{
  "name": "wohii-backend-exercise",
  "version": "1.0.0",
  "description": "WOHII project",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "cross-env DATABASE_URL=mysql://root:root@localhost:3306/cms_test prisma migrate deploy",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "uef"
  ],
  "author": "Matias Martikainen",
  "license": "ISC",
  "dependencies": {
    "@api/smtp2goapi": "file:.api/apis/smtp2goapi",
    "@prisma/client": "^6.19.3",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}
